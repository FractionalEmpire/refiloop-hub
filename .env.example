# Supabase (get from https://supabase.com/dashboard/project/dxvanitpqvvxvroywdml/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://dxvanitpqvvxvroywdml.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Auth passwords for each user
DAVID_PASSWORD=your_david_password_here
GORJAN_PASSWORD=your_gorjan_password_here

# GitHub API (for docs viewer/editor — personal access token with repo read/write)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=FractionalEmpire
GITHUB_REPO=refiloop-config

# Cookie secret (any random string, 32+ chars)
COOKIE_SECRET=change_me_to_a_random_string_32chars

# Gmail API — for sending emails from david@refiloop.com and monitoring inbox for replies
# Setup: node scripts/gmail-auth.js  (one-time OAuth flow to get the refresh token)
# Google Cloud Console: enable Gmail API, create Desktop OAuth2 credentials
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token
